# =============================================================================
# Bedrock IaC Agent — example configuration file
# =============================================================================
# Copy this file to config.yaml and fill in your values:
#
#   cp config.yaml.example config.yaml
#
# The agent searches for config.yaml in the following order:
#   1. Path passed via --config CLI flag or BEDROCK_IAC_CONFIG env var
#   2. ./config.yaml  (current working directory)
#   3. ~/.bedrock-iac-agent/config.yaml
#
# SECURITY NOTE: Never commit config.yaml to version control if it contains
# real credentials. Use environment variables for sensitive values instead.
#
# Environment variable overrides (highest priority — override file values):
#   GITHUB_TOKEN         → github.token
#   GITHUB_ORG           → github.organization
#   GITHUB_REPO          → github.repository
#   GITHUB_REPO_URL      → github.repo_url
#   BEDROCK_MODEL_ID     → bedrock.model_id
#   AWS_REGION           → bedrock.region
#   AWS_DEFAULT_REGION   → bedrock.region  (standard AWS SDK variable)
#   AWS_PROFILE          → bedrock.aws_profile
# =============================================================================


# ---------------------------------------------------------------------------
# GitHub credentials and repository settings
# ---------------------------------------------------------------------------
# The agent needs access to the GitHub repository that contains your Golden
# Modules and Terraform configurations. It will clone the repo, create a
# branch, commit the generated tfvars file, and open a Pull Request.
#
# Required scopes for the personal access token:
#   - repo          (read/write access to private repositories)
#   - pull_request  (create and manage pull requests)
#
# Generate a token at: https://github.com/settings/tokens
# ---------------------------------------------------------------------------
github:
  # Personal access token.
  # RECOMMENDED: Set via GITHUB_TOKEN env var instead of storing here.
  # Example: export GITHUB_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
  token: ""

  # GitHub organisation (or user account) that owns the base repository.
  # Example: "my-company" or "my-username"
  organization: "my-org"

  # Repository name — without the organisation prefix.
  # Example: "infrastructure" or "terraform-modules"
  repository: "my-infra-repo"

  # Full HTTPS clone URL of the repository.
  # Optional — derived automatically from organisation + repository if omitted.
  # Useful when the repository is hosted on GitHub Enterprise with a custom domain.
  # Example: "https://github.mycompany.com/my-org/my-infra-repo.git"
  repo_url: "https://github.com/my-org/my-infra-repo.git"


# ---------------------------------------------------------------------------
# AWS Bedrock model and region settings
# ---------------------------------------------------------------------------
# The agent uses AWS Bedrock to parse natural language requests. It selects
# economic models to keep operational costs low.
#
# Supported economic models (cheapest first):
#   anthropic.claude-3-haiku-20240307-v1:0  ← default, fast and cheap
#   amazon.nova-micro-v1:0                  ← Amazon's most economical
#   amazon.nova-lite-v1:0                   ← slightly more capable
#
# Before using a model, enable it in the AWS console:
#   Amazon Bedrock → Model access → Enable the model for your region
#
# AWS credentials are resolved via the standard credential chain:
#   1. Environment variables (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY)
#   2. Named profile (aws_profile setting below, or AWS_PROFILE env var)
#   3. IAM instance/task role (EC2, ECS, Lambda)
#   4. ~/.aws/credentials file
# ---------------------------------------------------------------------------
bedrock:
  # Bedrock model ID for natural language parsing.
  # Override with: export BEDROCK_MODEL_ID="amazon.nova-micro-v1:0"
  model_id: "anthropic.claude-3-haiku-20240307-v1:0"

  # AWS region where Bedrock is available.
  # Bedrock is available in: us-east-1, us-west-2, eu-west-1, ap-southeast-1, and others.
  # Override with: export AWS_DEFAULT_REGION="us-west-2"
  region: "us-east-1"

  # Optional AWS named profile from ~/.aws/config.
  # Set to null (or omit) to use the default credential chain.
  # Example: "dev-account" or "prod-readonly"
  # Override with: export AWS_PROFILE="my-profile"
  aws_profile: null


# ---------------------------------------------------------------------------
# Naming conventions for generated resources
# ---------------------------------------------------------------------------
# These settings control how the agent names the AWS resources it creates.
# The naming pattern applied is:
#
#   [prefix][separator][resource_name][separator][environment]
#
# Examples with prefix="mycompany", separator="-", environment_suffix=true:
#   S3 bucket "data-lake" in dev  → "mycompany-data-lake-dev"
#   Lambda "processor" in prod    → "mycompany-processor-prod"
#
# Examples with prefix="" (empty), separator="-", environment_suffix=true:
#   S3 bucket "data-lake" in dev  → "data-lake-dev"
#   Lambda "processor" in prod    → "processor-prod"
# ---------------------------------------------------------------------------
naming:
  # Optional prefix prepended to all resource names.
  # Use your company or project name to avoid naming collisions.
  # Leave empty ("") to skip the prefix.
  # Example: "acme" → resources named "acme-bucket-dev"
  prefix: ""

  # Whether to append the environment name as a suffix.
  # true  → "my-bucket-dev", "my-bucket-prod"
  # false → "my-bucket" (no environment suffix)
  environment_suffix: true

  # Character used to join name parts (prefix, resource name, environment).
  # Common choices: "-" (hyphen) or "_" (underscore).
  # Note: some AWS resources do not allow underscores in names.
  separator: "-"

  # Maximum length for generated resource names (in characters).
  # AWS resource name limits vary:
  #   S3 bucket names: 3–63 characters
  #   Lambda function names: up to 64 characters
  #   IAM role names: up to 64 characters
  # The default of 63 is safe for most resource types.
  max_length: 63

  # Regex character class defining allowed characters in resource names.
  # The default "[a-z0-9\\-]" enforces lowercase alphanumeric + hyphens,
  # which is compatible with all 12 Golden Module resource types.
  allowed_characters: "[a-z0-9\\-]"


# ---------------------------------------------------------------------------
# Logging configuration
# ---------------------------------------------------------------------------
# Controls log levels, output destinations, and log rotation for production.
#
# Environment variable overrides:
#   LOG_LEVEL          → logging.level
#   LOG_FILE           → logging.file.path  (also enables file logging)
#   LOG_FILE_ENABLED   → logging.file.enabled  ("true" / "false")
# ---------------------------------------------------------------------------
logging:
  # Root log level for the bedrock_iac_agent logger hierarchy.
  # Valid values: DEBUG | INFO | WARNING | ERROR | CRITICAL
  # Use DEBUG for development, INFO or WARNING for production.
  level: INFO

  # Console (stderr) handler settings.
  console:
    enabled: true
    # Optional per-handler level override.  Defaults to the root level above.
    # level: INFO

  # File handler settings.
  file:
    # Set to true to write logs to a file in addition to (or instead of) the console.
    enabled: false

    # Path to the log file.  Relative paths are resolved from the working directory.
    # Override with: export LOG_FILE="/var/log/bedrock-iac-agent/agent.log"
    path: logs/bedrock-iac-agent.log

    # Optional per-handler level override.  Defaults to the root level above.
    # Useful to write DEBUG logs to file while keeping the console at INFO.
    # level: DEBUG

    # Log rotation settings (only used when file.enabled is true).
    rotation:
      # Enable rotating file handler (RotatingFileHandler).
      # When false, a plain FileHandler is used (no rotation).
      enabled: true

      # Maximum size of a single log file in bytes before rotation.
      # Default: 10485760 (10 MB)
      max_bytes: 10485760

      # Number of rotated backup files to keep.
      # e.g. backup_count: 5 keeps agent.log, agent.log.1 … agent.log.5
      backup_count: 5
